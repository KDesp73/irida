#!/usr/bin/env python3

import subprocess
import argparse
import re
import sys

def eval(depth, fen):
    proc = subprocess.Popen(["stockfish"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True)
    commands = [
        "uci",
        f"position fen {fen}",
        f"go depth {depth}"
    ]

    for cmd in commands:
        proc.stdin.write(cmd + "\n")
    proc.stdin.flush()

    eval_cp = None

    # Read output
    while True:
        line = proc.stdout.readline().strip()
        if line.startswith(f"info depth {depth}") and "score cp" in line:
            match = re.search(r"score cp (-?\d+)", line)
            if match:
                eval_cp = int(match.group(1))
        elif "bestmove" in line:
            break

    proc.kill()

    if eval_cp is not None:
        print(eval_cp)

if __name__ == "__main__":
    parser = argparse.ArgumentParser("stockfisheval")
    parser.add_argument("--depth", help="Max search depth for Stockfish", type=int, default=15)
    parser.add_argument("--file", help="File containing FEN strings, one per line", type=str)
    parser.add_argument("fen", nargs="?", help="A single FEN string", type=str)
    args = parser.parse_args()

    depth = args.depth

    if args.file:
        try:
            with open(args.file, "r") as f:
                for line in f:
                    fen = line.strip()
                    if fen:
                        if not fen.startswith("#"):
                            print(fen)
                            eval(depth, fen)
        except FileNotFoundError:
            print(f"Error: File '{args.file}' not found.", file=sys.stderr)
            sys.exit(1)
    elif args.fen:
        eval(depth, args.fen)
    else:
        print("Error: Provide either --file or a FEN string.", file=sys.stderr)
        sys.exit(1)
