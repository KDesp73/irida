#!/usr/bin/env python3

import chess
import chess.engine
import chess.pgn
import chess.polyglot
import argparse
import logging
import re
import os
import random
from datetime import datetime
from colorama import Fore, init

init(autoreset=True)

def sanitize_filename(name):
    """Removes characters that aren't allowed in filenames."""
    return re.sub(r'[^\w\s-]', '', name).strip().replace(' ', '_')

def play_match(engine1_path, engine2_path, num_games, time_limit, book_path=None, debug=False):
    if debug:
        logging.basicConfig(format='%(levelname)s:%(name)s:%(message)s', level=logging.DEBUG)

    e1, e2 = None, None
    
    try:
        # Start engines
        e1 = chess.engine.SimpleEngine.popen_uci(engine1_path)
        e2 = chess.engine.SimpleEngine.popen_uci(engine2_path)
        
        # Parse Names and Versions
        name1 = e1.id.get("name", "Engine1")
        name2 = e2.id.get("name", "Engine2")
        ver1 = e1.id.get("version", "")
        ver2 = e2.id.get("version", "")
        
        full_n1 = f"{name1} {ver1} as E1".strip()
        full_n2 = f"{name2} {ver2} as E2".strip()
        
        results = {full_n1: 0, full_n2: 0, "Draws": 0}

        # Ensure directory exists
        os.makedirs("data/pgn/arena", exist_ok=True)
        
        # Create dynamic filename
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        safe_n1 = sanitize_filename(name1)
        safe_n2 = sanitize_filename(name2)
        filename = f"data/pgn/arena/Match_{safe_n1}_vs_{safe_n2}_{timestamp}.pgn"

        print(f"{Fore.CYAN}Match: {Fore.GREEN}{full_n1} {Fore.CYAN}vs {Fore.MAGENTA}{full_n2}")
        if book_path:
            print(f"{Fore.YELLOW}Opening Book: {Fore.WHITE}{book_path}")
        print(f"{Fore.BLUE}Logging to: {Fore.WHITE}{filename}\n")

        for game_num in range(1, num_games + 1):
            board = chess.Board()
            game_time = datetime.now()
            
            game = chess.pgn.Game()
            game.headers["Event"] = "Engine V Engine"
            game.headers["Site"] = "Local Arena"
            game.headers["Date"] = game_time.strftime("%Y.%m.%d")
            game.headers["Round"] = str(game_num)
            
            # Determine colors
            if game_num % 2 != 0:
                white_engine, black_engine = e1, e2
                game.headers["White"], game.headers["Black"] = full_n1, full_n2
                w_label, b_label = "E1", "E2"
            else:
                white_engine, black_engine = e2, e1
                game.headers["White"], game.headers["Black"] = full_n2, full_n1
                w_label, b_label = "E2", "E1"

            print(f"{Fore.WHITE}Game {game_num:02d} | {w_label}(W) vs {b_label}(B)", end=" ", flush=True)

            aborted = False
            node = game 
            
            # Opening Book Logic
            book_reader = None
            if book_path and os.path.exists(book_path):
                book_reader = chess.polyglot.open_reader(book_path)

            while not board.is_game_over() and not aborted:
                current_engine = white_engine if board.turn == chess.WHITE else black_engine
                move = None

                # 1. Try Book Move
                if book_reader:
                    try:
                        entries = list(book_reader.find_all(board))
                        if entries:
                            # Use weight-based selection for variety
                            selection = book_reader.weighted_choice(board)
                            move = selection.move
                        else:
                            book_reader.close()
                            book_reader = None # Book exhausted
                    except Exception:
                        book_reader = None

                # 2. Try Engine Move
                if move is None:
                    try:
                        result = current_engine.play(board, chess.engine.Limit(time=time_limit))
                        move = result.move
                    except Exception:
                        aborted = True

                # 3. Apply Move
                if move:
                    node = node.add_main_variation(move)
                    board.push(move)
                else:
                    aborted = True

            # Close reader if still open
            if book_reader:
                book_reader.close()

            # Finalize Result
            if aborted:
                res_str = "0-1" if board.turn == chess.WHITE else "1-0"
                game.headers["Result"] = res_str
            else:
                game.headers["Result"] = board.result()
            
            # Update Score
            res = game.headers["Result"]
            if res == "1-0":
                results[game.headers["White"]] += 1
            elif res == "0-1":
                results[game.headers["Black"]] += 1
            else:
                results["Draws"] += 1

            print(f"{Fore.YELLOW}{res}")
            
            with open(filename, "a") as f:
                f.write(str(game) + "\n\n")

    finally:
        if e1: e1.quit()
        if e2: e2.quit()

    return results, full_n1, full_n2, filename

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="UCI Engine Match Runner")
    parser.add_argument("engine1", type=str, help="Path to Engine 1 binary")
    parser.add_argument("engine2", type=str, help="Path to Engine 2 binary")
    parser.add_argument("--games", type=int, default=10, help="Number of games")
    parser.add_argument("--time", type=float, default=0.1, help="Seconds per move")
    parser.add_argument("--book", type=str, default=None, help="Path to polyglot .bin book")
    parser.add_argument("--debug", action="store_true", help="Enable debug logging")
    
    args = parser.parse_args()

    res, n1, n2, fname = play_match(
        args.engine1, 
        args.engine2, 
        args.games, 
        args.time, 
        book_path=args.book,
        debug=args.debug
    )
    
    print(f"\n{Fore.GREEN}FINAL SCORE: {n1} ({res[n1]}) - {n2} ({res[n2]}) | Draws: {res['Draws']}")
    print(f"File saved: {fname}")
