#!/usr/bin/env python3

import chess.pgn
import matplotlib.pyplot as plt
import numpy as np
import argparse
import sys
import math
from collections import defaultdict

def calculate_elo_diff(win_rate):
    if win_rate <= 0 or win_rate >= 100:
        return 0
    return -400 * math.log10(1 / (win_rate / 100) - 1)

def parse_pgn(file_path):
    stats = defaultdict(lambda: {'W': [0, 0, 0], 'B': [0, 0, 0]})
    game_lengths = []
    
    try:
        with open(file_path, encoding="utf-8") as pgn_file:
            while True:
                game = chess.pgn.read_game(pgn_file)
                if game is None: break
                
                white = game.headers.get("White", "Unknown")
                black = game.headers.get("Black", "Unknown")
                res = game.headers.get("Result", "*")
                
                # Track game length (plies to full moves)
                move_count = sum(1 for _ in game.mainline_moves())
                game_lengths.append(move_count / 2)

                if res == "1-0":
                    stats[white]['W'][0] += 1
                    stats[black]['B'][1] += 1
                elif res == "0-1":
                    stats[white]['W'][1] += 1
                    stats[black]['B'][0] += 1
                elif res == "1/2-1/2":
                    stats[white]['W'][2] += 1
                    stats[black]['B'][2] += 1
                    
        return stats, game_lengths
    except Exception as e:
        print(f"Error reading PGN: {e}")
        sys.exit(1)

def plot_outcomes(stats, engines):
    wins = [((stats[e]['W'][0] + stats[e]['B'][0]) / (sum(stats[e]['W']) + sum(stats[e]['B']))) * 100 for e in engines]
    draws = [((stats[e]['W'][2] + stats[e]['B'][2]) / (sum(stats[e]['W']) + sum(stats[e]['B']))) * 100 for e in engines]
    losses = [100 - (w + d) for w, d in zip(wins, draws)]

    plt.bar(engines, wins, label='Wins', color='#2ecc71')
    plt.bar(engines, draws, bottom=wins, label='Draws', color='#bdc3c7')
    plt.bar(engines, losses, bottom=[i+j for i,j in zip(wins, draws)], label='Losses', color='#e74c3c')
    plt.title("Win/Loss/Draw Distribution")
    plt.ylabel("Percentage")
    plt.legend()

def plot_colors(stats, engines):
    indices = np.arange(len(engines))
    width = 0.35
    w_perf = [((stats[e]['W'][0] + 0.5 * stats[e]['W'][2]) / sum(stats[e]['W']) * 100) if sum(stats[e]['W']) > 0 else 0 for e in engines]
    b_perf = [((stats[e]['B'][0] + 0.5 * stats[e]['B'][2]) / sum(stats[e]['B']) * 100) if sum(stats[e]['B']) > 0 else 0 for e in engines]

    plt.bar(indices - width/2, w_perf, width, label='White', color='#f1c40f')
    plt.bar(indices + width/2, b_perf, width, label='Black', color='#34495e')
    plt.axhline(y=50, color='r', linestyle='--', alpha=0.3)
    plt.xticks(indices, engines)
    plt.title("Performance by Side")
    plt.ylabel("Win Rate %")
    plt.legend()

def plot_length(lengths):
    plt.hist(lengths, bins=20, color='#9b59b6', edgecolor='black')
    plt.title("Game Length Distribution")
    plt.xlabel("Number of Full Moves")
    plt.ylabel("Number of Games")

def main():
    parser = argparse.ArgumentParser(description="Chess Engine A/B Testing CLI")
    parser.add_argument("pgn", help="Path to the PGN file")
    parser.add_argument("-o", "--outcomes", action="store_true", help="Show Win/Loss/Draw stacked bar")
    parser.add_argument("-c", "--color", action="store_true", help="Show White vs Black performance")
    parser.add_argument("-l", "--length", action="store_true", help="Show game length histogram")
    parser.add_argument("-a", "--all", action="store_true", help="Show all diagrams")

    args = parser.parse_args()
    
    stats, lengths = parse_pgn(args.pgn)
    engines = list(stats.keys())

    # Text Summary
    print(f"\n{'Engine':<20} | {'Win%':<8} | {'Elo Diff':<10}")
    print("-" * 45)
    for eng in engines:
        total = sum(stats[eng]['W']) + sum(stats[eng]['B'])
        points = (stats[eng]['W'][0] + stats[eng]['B'][0]) + 0.5 * (stats[eng]['W'][2] + stats[eng]['B'][2])
        wr = (points / total) * 100
        print(f"{eng[:20]:<20} | {wr:>6.2f}% | {calculate_elo_diff(wr):>+8.1f}")

    # Plot Selection
    plots_to_show = []
    if args.outcomes or args.all: plots_to_show.append('outcomes')
    if args.color or args.all: plots_to_show.append('color')
    if args.length or args.all: plots_to_show.append('length')

    if plots_to_show:
        fig = plt.figure(figsize=(len(plots_to_show) * 5, 5))
        for i, ptype in enumerate(plots_to_show):
            plt.subplot(1, len(plots_to_show), i + 1)
            if ptype == 'outcomes': plot_outcomes(stats, engines)
            elif ptype == 'color': plot_colors(stats, engines)
            elif ptype == 'length': plot_length(lengths)
        
        plt.tight_layout()
        plt.show()
    else:
        print("\nNo diagrams selected. Use -o, -c, -l, or -a.")

if __name__ == "__main__":
    main()
