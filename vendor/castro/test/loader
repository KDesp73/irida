#!/usr/bin/env python3
import os
import argparse
from typing import List

class Log:
    # ANSI escape codes
    CYAN = "\033[96m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    RED = "\033[91m"
    BOLD = "\033[1m"
    END = "\033[0m"

    @staticmethod
    def info(msg):
        print(f"{Log.CYAN}{Log.BOLD}[INFO]{Log.END} {msg}")

    @staticmethod
    def success(msg):
        print(f"{Log.GREEN}{Log.BOLD}[PASS]{Log.END} {msg}")

    @staticmethod
    def step(msg):
        print(f"{Log.YELLOW}  →{Log.END} {msg}")

    @staticmethod
    def error(msg):
        print(f"{Log.RED}{Log.BOLD}[ERRO]{Log.END} {msg}")

def find_tests(test_dir: str):
    ctd_files = [f for f in os.listdir(test_dir) if f.endswith('.ctd')]
    test_names = [f[:-4] for f in ctd_files]

    if not test_names:
        Log.error("No .ctd files found. Nothing to generate.")
        return None

    return test_names


def generate_registry(test_dir: str, header: str, test_names: List[str]):
    REGISTRY_FILE = f"{test_dir}/registry.h"

    try:
        with open(REGISTRY_FILE, "w") as r:
            header = f"""
#ifndef TEST_REGISTRY_H
#define TEST_REGISTRY_H

#include <string.h>
#include "{header}"

"""
            r.write(header)
            for name in test_names:
                r.write(f'#include "{name}.h"\n')
            
            r.write("\n// Auto-generated dispatcher\n")
            r.write("static int dispatch_test_by_name(const char* name) {\n")
            for name in test_names:
                r.write(f'    if (strcmp(name, "{name}") == 0) return test(TEST_{name}, END);\n')
            r.write("    return 1;\n}\n\n#endif")
        Log.success(f"Generated registry: {Log.BOLD}{REGISTRY_FILE}{Log.END}")
    except Exception as e:
        Log.error(f"Failed to write registry: {e}")


def generate_header(test_dir: str, lib: str, name: str):
    c_path = f"{test_dir}/{name}.c"
    ctd_path = f"{test_dir}/{name}.ctd"
    h_path = f"{test_dir}/{name}.h"

    definition = None

    try:
        with open(c_path, "r") as c:
            line = [line for line in c.readlines() if name in line][0]
            definition = line.rstrip('{; \n')
            definition = definition + ";"
    
        with open(ctd_path, "r") as f:
            lines = [l.strip() for l in f if l.strip() and not l.startswith('#')]
        
        with open(h_path, "w") as h:
            h.write(f"// Autogenerated by test.h's `generate` script from {ctd_path}\n")
            h.write(f"#ifndef {name}_h\n#define {name}_h\n\n")
            h.write(f"#include \"{lib}\"\n")
            h.write(f"{definition}\n\n")
            h.write(f"#define TEST_{name} ")
            if lines:
                formatted_lines = [f"\t{name}({line})" for line in lines]
                h.write("\\\n" + ", \\\n".join(formatted_lines) + "\n")
            else:
                h.write("1\n")
            h.write("\n#endif\n")
        Log.step(f"Mapped {Log.BOLD}{name}.ctd{Log.END} ({len(lines)} cases)")
    except Exception as e:
        Log.error(f"Failed processing {name}: {e}")


def generate_headers(test_dir: str, lib: str, test_names: List[str]):
    for name in test_names:
        generate_header(test_dir, lib, name)


def generate(test_dir: str, header: str, lib: str):
    
    if not os.path.exists(test_dir):
        Log.error(f"Directory '{test_dir}' not found.")
        return

    Log.info(f"Scanning directory: {Log.BOLD}{test_dir}{Log.END}")
    test_names = find_tests(test_dir)
    if not test_names:
        return

    # 1. Generate Registry
    generate_registry(test_dir, header, test_names)

    # 2. Generate Individual Headers
    Log.info(f"Generating headers for {len(test_names)} tests...")
    generate_headers(test_dir, lib, test_names)

    Log.success("All test headers synchronized.")

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("-d", "--dir", default="test", help="Provide the test directory")
    parser.add_argument("-H", "--header", default="test.h", help="Specify the header path")
    parser.add_argument("-L", "--lib", help="Specify a library header to include with the tests")
    args = parser.parse_args()

    generate(args.dir, args.header, args.lib)
